@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Create Role";
}


<div class="container mt-4">
    <h2>Create New Role</h2>

    <form id="createRoleForm" class="mt-4">
        <div class="form-group mb-3">
            <label for="name">Name</label>

            <input type="text" class="form-control" id="name" required>
        </div>

        <button type="submit" class="btn btn-primary">Create Role</button>
        <a href="/Roles" class="btn btn-secondary">Back to List</a>
    </form>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
    <script>
        $(document).ready(function () {
            $('#createRoleForm').submit(function (e) {
                e.preventDefault();
                
                const roleData = {
                    name: $('#name').val()
                };
                
                axios.post('/api/roles', roleData)
                    .then(function(response) {
                        if (response.data.success) {
                            alert('Role created successfully');
                            window.location.href = '/Roles';
                        } else {
                            alert(response.data.message || 'Failed to create role');
                        }
                    })
                    .catch(function(error) {
                        console.error('Error creating role:', error);
                        if (error.response && error.response.data) {
                            alert(error.response.data.message || 'Failed to create role');
                        } else {
                            alert('Failed to create role');
                        }
                    });
            });
        });
    </script>
}
