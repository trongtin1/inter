@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Roles";
}

<div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Roles</h2>
        <a href="/Roles/Create" class="btn btn-success">Create New Role</a>
    </div>


    <table class="table" id="rolesTable">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>

            <!-- Data sẽ được thêm vào đây -->
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            loadRoles();
        });


        async function loadRoles() {
            try {
                const response = await axios.get('/api/Roles');

                const roles = response.data.data;
                const tbody = $('#rolesTable tbody');

                tbody.empty();
                roles.forEach(role => {
                    tbody.append(`
                        <tr>

                            <td>${role.id}</td>
                            <td>${role.name}</td>
                            <td>
                                <button class="btn btn-primary btn-sm edit-role" data-id="${role.id}">Edit</button>
                                
                            </td>

                        </tr>
                    `);
                });

                // Gắn sự kiện click cho nút Edit
                $('.edit-role').on('click', function () {
                    const roleId = $(this).data('id');
                    editRole(roleId);
                });


                // Gắn sự kiện click cho nút Delete
                $('.delete-role').on('click', function () {
                    const roleId = $(this).data('id');
                    deleteRole(roleId);
                });


            } catch (error) {
                console.error('Error loading roles:', error);
                alert('Failed to load roles');
            }
        }


        function editRole(id) {
            window.location.href = `/Roles/Edit/${id}`;
        }


        async function deleteRole(id) {
            if (confirm('Are you sure you want to delete this role?')) {
                try {
                    await axios.delete(`/api/Roles/${id}`);
                    loadRoles(); // Reload lại danh sách sau khi xóa

                } catch (error) {
                    console.error('Error deleting role:', error);
                    alert('Failed to delete role');
                }
            }
        }
    </script>

}
